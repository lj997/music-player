<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.musicplayer.mapper.MusicFolderMapper">
    <resultMap id="MusicFolderResultMap" type="com.musicplayer.entity.MusicFolder">
        <id column="id" property="id"/>
        <result column="folder_path" property="folderPath"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="MusicFolderResultMap">
        SELECT * FROM music_folder WHERE id = #{id}
    </select>

    <select id="selectByPath" resultMap="MusicFolderResultMap">
        SELECT * FROM music_folder WHERE folder_path = #{path}
    </select>

    <select id="selectAll" resultMap="MusicFolderResultMap">
        SELECT * FROM music_folder ORDER BY create_time
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO music_folder (folder_path)
        VALUES (#{folderPath})
    </insert>

    <delete id="deleteById">
        DELETE FROM music_folder WHERE id = #{id}
    </delete>
</mapper>